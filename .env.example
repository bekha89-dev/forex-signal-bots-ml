# ─────────────────────────────────────────────────────────────
#  Forex Signal Pack — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in your real values below
#  3. Never commit .env to Git (it's already in .gitignore)
# ─────────────────────────────────────────────────────────────

# TwelveData API key (free tier: https://twelvedata.com)
TWELVE_DATA_KEY=your_twelvedata_api_key_here

# Telegram Bot token (from @BotFather on Telegram)
TELEGRAM_TOKEN=123456789:ABCDEFabcdef_your_token_here

# Your Telegram chat ID (get it from @userinfobot)
TELEGRAM_CHAT_ID=123456789
